func namePatternToRegex(pattern string) (string, error) {
	if !bulkInstanceNamePatternRe.MatchString(pattern) {
		return "", fmt.Errorf("name_pattern must contain exactly one continuous sequence of # characters")
	}

	match := bulkInstanceHashPlaceholderRe.FindStringIndex(pattern)
	if match == nil {
		return "", fmt.Errorf("name_pattern must contain at least one # character")
	}
	if match[1]-match[0] > 18 {
		return "", fmt.Errorf("name_pattern can contain at most 18 consecutive # characters")
	}

	digitPattern := "[0-9]{" + fmt.Sprintf("%d", match[1]-match[0]) + "}"
	return regexp.QuoteMeta(pattern[:match[0]]) + digitPattern + regexp.QuoteMeta(pattern[match[1]:]), nil
}

func listBulkInstancesMatchingPattern(config *transport_tpg.Config, project, zone, pattern, userAgent string) ([]*compute.Instance, error) {
	patternRegex, err := namePatternToRegex(pattern)
	if err != nil {
		return nil, err
	}

	re, err := regexp.Compile("^" + patternRegex + "$")
	if err != nil {
		return nil, fmt.Errorf("invalid name pattern: %s", err)
	}

	var matchingInstances []*compute.Instance
	pageToken := ""
	for {
		listCall := config.NewComputeClient(userAgent).Instances.List(project, zone)
		if pageToken != "" {
			listCall = listCall.PageToken(pageToken)
		}
		instances, err := listCall.Do()
		if err != nil {
			return nil, err
		}
		for _, inst := range instances.Items {
			if re.MatchString(inst.Name) {
				matchingInstances = append(matchingInstances, inst)
			}
		}
		if instances.NextPageToken == "" {
			break
		}
		pageToken = instances.NextPageToken
	}

	return matchingInstances, nil
}

func listBulkInstancesWithNames(config *transport_tpg.Config, project, zone string, names []string, userAgent string) ([]*compute.Instance, error) {
	if len(names) == 0 {
		return nil, nil
	}

	nameSet := make(map[string]struct{}, len(names))
	for _, name := range names {
		if name != "" {
			nameSet[name] = struct{}{}
		}
	}

	var matchingInstances []*compute.Instance
	pageToken := ""
	for {
		listCall := config.NewComputeClient(userAgent).Instances.List(project, zone)
		if pageToken != "" {
			listCall = listCall.PageToken(pageToken)
		}
		instances, err := listCall.Do()
		if err != nil {
			return nil, err
		}
		for _, inst := range instances.Items {
			if _, ok := nameSet[inst.Name]; ok {
				matchingInstances = append(matchingInstances, inst)
			}
		}
		if instances.NextPageToken == "" {
			break
		}
		pageToken = instances.NextPageToken
	}

	return matchingInstances, nil
}

func listTrackedBulkInstances(config *transport_tpg.Config, project, zone, namePattern string, explicitNames []string, userAgent string) ([]*compute.Instance, error) {
	trackedByName := make(map[string]*compute.Instance)

	if namePattern != "" {
		matchingInstances, err := listBulkInstancesMatchingPattern(config, project, zone, namePattern, userAgent)
		if err != nil {
			return nil, err
		}
		for _, inst := range matchingInstances {
			if inst != nil && inst.Name != "" {
				trackedByName[inst.Name] = inst
			}
		}
	}

	if len(explicitNames) > 0 {
		matchingInstances, err := listBulkInstancesWithNames(config, project, zone, explicitNames, userAgent)
		if err != nil {
			return nil, err
		}
		for _, inst := range matchingInstances {
			if inst != nil && inst.Name != "" {
				trackedByName[inst.Name] = inst
			}
		}
	}

	names := make([]string, 0, len(trackedByName))
	for name := range trackedByName {
		names = append(names, name)
	}
	sort.Strings(names)

	instances := make([]*compute.Instance, 0, len(names))
	for _, name := range names {
		instances = append(instances, trackedByName[name])
	}
	return instances, nil
}

func sortedBulkInstanceNames(instances []*compute.Instance) []string {
	names := make([]string, 0, len(instances))
	for _, inst := range instances {
		if inst != nil && inst.Name != "" {
			names = append(names, inst.Name)
		}
	}
	sort.Strings(names)
	return names
}

func expandBulkInstanceStateNames(d *schema.ResourceData) []string {
	rawNames := d.Get("instance_names").([]interface{})
	names := make([]string, 0, len(rawNames))
	for _, rawName := range rawNames {
		name, ok := rawName.(string)
		if ok && name != "" {
			names = append(names, name)
		}
	}
	sort.Strings(names)
	return names
}

func setBulkInstanceState(d *schema.ResourceData, instances []*compute.Instance) error {
	names := sortedBulkInstanceNames(instances)
	if err := d.Set("instance_names", names); err != nil {
		return err
	}
	if err := d.Set("current_instance_count", len(names)); err != nil {
		return err
	}
	return nil
}

func normalizeBulkInsertStringMap(raw interface{}) map[string]string {
	normalized := make(map[string]string)
	rawMap, ok := raw.(map[string]interface{})
	if !ok || rawMap == nil {
		return normalized
	}

	for key, value := range rawMap {
		stringValue, ok := value.(string)
		if !ok {
			continue
		}
		normalized[key] = stringValue
	}

	return normalized
}

func expandBulkInstancePerInstanceProperties(d *schema.ResourceData) map[string]compute.BulkInsertInstanceResourcePerInstanceProperties {
	normalized := normalizeBulkInsertStringMap(d.Get("per_instance_properties"))
	if len(normalized) == 0 {
		return nil
	}

	expanded := make(map[string]compute.BulkInsertInstanceResourcePerInstanceProperties, len(normalized))
	for name, hostname := range normalized {
		props := compute.BulkInsertInstanceResourcePerInstanceProperties{}
		// Instance names are the JSON object keys in perInstanceProperties. The Go
		// client's BulkInsertInstanceResourcePerInstanceProperties.Name field is
		// documented as output-only/temporary, so we only set Hostname here.
		if hostname != "" {
			props.Hostname = hostname
		}
		expanded[name] = props
	}
	return expanded
}

func configuredBulkPerInstanceNames(d *schema.ResourceData) []string {
	normalized := normalizeBulkInsertStringMap(d.Get("per_instance_properties"))
	names := make([]string, 0, len(normalized))
	for name := range normalized {
		if name != "" {
			names = append(names, name)
		}
	}
	sort.Strings(names)
	return names
}

func bulkInstanceResourceID(project, zone, namePattern string, instanceNames []string) string {
	if namePattern != "" {
		return fmt.Sprintf("projects/%s/zones/%s/bulkInstances/%s", project, zone, namePattern)
	}
	return fmt.Sprintf("projects/%s/zones/%s/bulkInstances/named/%s", project, zone, strings.Join(instanceNames, ","))
}

func expandBulkInsertLocationPolicy(d *schema.ResourceData) *compute.LocationPolicy {
	rawPolicies, ok := d.GetOk("location_policy")
	if !ok {
		return nil
	}
	policies := rawPolicies.([]interface{})
	if len(policies) == 0 || policies[0] == nil {
		return nil
	}

	policyMap := policies[0].(map[string]interface{})
	locationPolicy := &compute.LocationPolicy{}

	if v, ok := policyMap["target_shape"].(string); ok && v != "" {
		locationPolicy.TargetShape = v
	}

	if rawLocations, ok := policyMap["location"].([]interface{}); ok && len(rawLocations) > 0 {
		locations := make(map[string]compute.LocationPolicyLocation, len(rawLocations))
		for _, rawLocation := range rawLocations {
			if rawLocation == nil {
				continue
			}
			locationMap := rawLocation.(map[string]interface{})
			zone, _ := locationMap["zone"].(string)
			if zone == "" {
				continue
			}
			location := compute.LocationPolicyLocation{}
			if v, ok := locationMap["preference"].(string); ok && v != "" {
				location.Preference = v
			}
			if v, ok := locationMap["max_count"].(int); ok {
				location.Constraints = &compute.LocationPolicyLocationConstraints{MaxCount: int64(v)}
			}
			locations[zone] = location
		}
		if len(locations) > 0 {
			locationPolicy.Locations = locations
		}
	}

	if rawZones, ok := policyMap["zones"].([]interface{}); ok && len(rawZones) > 0 {
		zones := make([]*compute.LocationPolicyZoneConfiguration, 0, len(rawZones))
		for _, rawZone := range rawZones {
			if rawZone == nil {
				continue
			}
			zoneMap := rawZone.(map[string]interface{})
			zone, _ := zoneMap["zone"].(string)
			if zone == "" {
				continue
			}
			zones = append(zones, &compute.LocationPolicyZoneConfiguration{Zone: zone})
		}
		if len(zones) > 0 {
			locationPolicy.Zones = zones
		}
	}

	if locationPolicy.TargetShape == "" && len(locationPolicy.Locations) == 0 && len(locationPolicy.Zones) == 0 {
		return nil
	}
	return locationPolicy
}

func expandBulkInsertInstanceFlexibilityPolicy(d *schema.ResourceData, config *transport_tpg.Config) (*compute.InstanceFlexibilityPolicy, error) {
	rawPolicies, ok := d.GetOk("instance_flexibility_policy")
	if !ok {
		return nil, nil
	}
	policies := rawPolicies.([]interface{})
	if len(policies) == 0 || policies[0] == nil {
		return nil, nil
	}

	policyMap := policies[0].(map[string]interface{})
	rawSelections, ok := policyMap["instance_selection"].([]interface{})
	if !ok || len(rawSelections) == 0 {
		return nil, nil
	}

	selections := make(map[string]compute.InstanceFlexibilityPolicyInstanceSelection, len(rawSelections))
	for _, rawSelection := range rawSelections {
		if rawSelection == nil {
			continue
		}
		selectionMap := rawSelection.(map[string]interface{})
		name, _ := selectionMap["name"].(string)
		if name == "" {
			continue
		}

		selection := compute.InstanceFlexibilityPolicyInstanceSelection{}
		if rawMachineTypes, ok := selectionMap["machine_types"].([]interface{}); ok && len(rawMachineTypes) > 0 {
			machineTypes := make([]string, 0, len(rawMachineTypes))
			for _, rawMachineType := range rawMachineTypes {
				machineType, ok := rawMachineType.(string)
				if ok && machineType != "" {
					machineTypes = append(machineTypes, machineType)
				}
			}
			selection.MachineTypes = machineTypes
		}
		if v, ok := selectionMap["rank"].(int); ok {
			selection.Rank = int64(v)
		}
		if rawDisks, ok := selectionMap["disk"].([]interface{}); ok && len(rawDisks) > 0 {
			flexDisks := make([]*compute.AttachedDisk, 0, len(rawDisks))
			for _, rawDisk := range rawDisks {
				if rawDisk == nil {
					continue
				}
				diskMap := rawDisk.(map[string]interface{})
				src, _ := diskMap["source"].(string)
				if src == "" {
					continue
				}
				diskCfg := map[string]interface{}{"source": src}
				if v, ok := diskMap["mode"]; ok {
					diskCfg["mode"] = v
				}
				if v, ok := diskMap["device_name"]; ok {
					diskCfg["device_name"] = v
				}
				if v, ok := diskMap["force_attach"]; ok {
					diskCfg["force_attach"] = v
				}
				ad, err := expandAttachedDisk(diskCfg, d, config)
				if err != nil {
					return nil, fmt.Errorf("instance_flexibility_policy disk %q: %w", name, err)
				}
				flexDisks = append(flexDisks, ad)
			}
			if len(flexDisks) > 0 {
				selection.Disks = sanitizeBulkInsertDisks(flexDisks)
			}
		}
		selections[name] = selection
	}

	if len(selections) == 0 {
		return nil, nil
	}
	return &compute.InstanceFlexibilityPolicy{InstanceSelections: selections}, nil
}

func expandBulkInsertMetadata(d *schema.ResourceData) (*compute.Metadata, error) {
	mdMap := normalizeBulkInsertStringMap(d.Get("metadata"))
	if v, ok := d.GetOk("metadata_startup_script"); ok {
		if startupScript, ok := v.(string); ok && startupScript != "" {
			if existing, ok := mdMap["startup-script"]; ok && existing != startupScript {
				return nil, fmt.Errorf("Cannot provide both metadata_startup_script and metadata.startup-script.")
			}
			mdMap["startup-script"] = startupScript
		}
	}

	if len(mdMap) == 0 {
		return nil, nil
	}

	keys := make([]string, 0, len(mdMap))
	for key := range mdMap {
		keys = append(keys, key)
	}
	sort.Strings(keys)

	items := make([]*compute.MetadataItems, 0, len(keys))
	for _, key := range keys {
		value := mdMap[key]
		valueCopy := value
		items = append(items, &compute.MetadataItems{
			Key:   key,
			Value: &valueCopy,
		})
	}

	return &compute.Metadata{Items: items}, nil
}

func expandBulkInsertTags(d *schema.ResourceData) *compute.Tags {
	rawTags, ok := d.GetOk("tags")
	if !ok || rawTags == nil {
		return nil
	}

	vs, ok := rawTags.(*schema.Set)
	if !ok || vs == nil || vs.Len() == 0 {
		return nil
	}

	items := make([]string, 0, vs.Len())
	for _, raw := range vs.List() {
		if raw == nil {
			continue
		}
		tag, ok := raw.(string)
		if !ok || tag == "" {
			continue
		}
		items = append(items, tag)
	}

	if len(items) == 0 {
		return nil
	}

	return &compute.Tags{Items: items}
}

func expandBulkInsertServiceAccounts(d *schema.ResourceData) []*compute.ServiceAccount {
	rawConfigs := d.Get("service_account").([]interface{})
	if len(rawConfigs) == 0 {
		return nil
	}

	accounts := make([]*compute.ServiceAccount, 0, len(rawConfigs))
	for _, raw := range rawConfigs {
		if raw == nil {
			continue
		}

		data, ok := raw.(map[string]interface{})
		if !ok {
			continue
		}

		account := &compute.ServiceAccount{}
		if rawEmail, ok := data["email"]; ok && rawEmail != nil {
			if email, ok := rawEmail.(string); ok && email != "" {
				account.Email = email
			}
		}
		if rawScopes, ok := data["scopes"]; ok && rawScopes != nil {
			if scopes, ok := rawScopes.(*schema.Set); ok && scopes != nil {
				account.Scopes = tpgresource.CanonicalizeServiceScopes(tpgresource.ConvertStringSet(scopes))
			}
		}

		if account.Email == "" && len(account.Scopes) == 0 {
			continue
		}
		accounts = append(accounts, account)
	}

	if len(accounts) == 0 {
		return nil
	}

	return accounts
}

func sanitizeBulkInsertDisks(disks []*compute.AttachedDisk) []*compute.AttachedDisk {
	sanitized := make([]*compute.AttachedDisk, len(disks))
	for i, disk := range disks {
		diskCopy := *disk
		if diskCopy.DiskEncryptionKey != nil {
			keyCopy := *diskCopy.DiskEncryptionKey
			keyCopy.RawKey = ""
			keyCopy.RsaEncryptedKey = ""
			diskCopy.DiskEncryptionKey = &keyCopy
		}
		if diskCopy.InitializeParams != nil && diskCopy.InitializeParams.SourceImageEncryptionKey != nil {
			keyCopy := *diskCopy.InitializeParams.SourceImageEncryptionKey
			keyCopy.RawKey = ""
			keyCopy.RsaEncryptedKey = ""
			diskCopy.InitializeParams.SourceImageEncryptionKey = &keyCopy
		}
		if diskCopy.InitializeParams != nil && diskCopy.InitializeParams.SourceSnapshotEncryptionKey != nil {
			keyCopy := *diskCopy.InitializeParams.SourceSnapshotEncryptionKey
			keyCopy.RawKey = ""
			keyCopy.RsaEncryptedKey = ""
			diskCopy.InitializeParams.SourceSnapshotEncryptionKey = &keyCopy
		}
		if diskCopy.InitializeParams != nil && diskCopy.InitializeParams.DiskType != "" {
			diskCopy.InitializeParams.DiskType = tpgresource.GetResourceNameFromSelfLink(diskCopy.InitializeParams.DiskType)
		}
		sanitized[i] = &diskCopy
	}
	return sanitized
}

func sanitizeBulkInsertGuestAccelerators(accels []*compute.AcceleratorConfig) []*compute.AcceleratorConfig {
	if len(accels) == 0 {
		return accels
	}
	out := make([]*compute.AcceleratorConfig, len(accels))
	for i, a := range accels {
		if a == nil {
			continue
		}
		cp := *a
		cp.AcceleratorType = tpgresource.GetResourceNameFromSelfLink(a.AcceleratorType)
		if cp.AcceleratorType == "" {
			cp.AcceleratorType = a.AcceleratorType
		}
		out[i] = &cp
	}
	return out
}

func sanitizeBulkInsertResourcePolicies(policies []string) []string {
	if len(policies) == 0 {
		return policies
	}
	out := make([]string, len(policies))
	for i, p := range policies {
		name := tpgresource.GetResourceNameFromSelfLink(p)
		if name == "" {
			name = p
		}
		out[i] = name
	}
	return out
}

func rawConfigHasTopLevelAttr(d *schema.ResourceData, attr string) bool {
	rawConfig := d.GetRawConfig()
	if rawConfig.IsNull() {
		return false
	}

	return !rawConfig.GetAttr(attr).IsNull()
}

