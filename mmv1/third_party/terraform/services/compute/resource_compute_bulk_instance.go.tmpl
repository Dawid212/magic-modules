var bulkInstanceNamePatternRe = regexp.MustCompile(`^[^#]*#+[^#]*$`)
var bulkInstanceHashPlaceholderRe = regexp.MustCompile(`#+`)

func ResourceComputeBulkInstance() *schema.Resource {
	return &schema.Resource{
		Create: resourceComputeBulkInstanceCreate,
		Read:   resourceComputeBulkInstanceRead,
		Delete: resourceComputeBulkInstanceDelete,

		Timeouts: ResourceComputeInstance().Timeouts,

		Schema:        computeBulkInstanceSchema(),
		CustomizeDiff: customdiff.All(
			tpgresource.DefaultProviderProject,
			tpgresource.DefaultProviderZone,
			resourceComputeBulkInstanceCustomizeDiff,
			tpgresource.SetLabelsDiff,
		),
		UseJSONNumber: true,
	}
}

func resourceComputeBulkInstanceCustomizeDiff(ctx context.Context, d *schema.ResourceDiff, meta interface{}) error {
	namePattern := d.Get("name_pattern").(string)
	perInstanceProperties := normalizeBulkInsertStringMap(d.Get("per_instance_properties"))
	if namePattern == "" && len(perInstanceProperties) == 0 {
		return fmt.Errorf("either name_pattern or per_instance_properties must be set")
	}
	// Zonal instances.bulkInsert rejects these even though they appear on the REST discovery shape.
	if raw := d.Get("location_policy"); raw != nil {
		if lp, ok := raw.([]interface{}); ok && len(lp) > 0 && lp[0] != nil {
			return fmt.Errorf("location_policy is not supported on zonal instances.bulkInsert, which is the only API used by google_compute_bulk_instance (regional bulk insert only)")
		}
	}
	if raw := d.Get("instance_flexibility_policy"); raw != nil {
		if fp, ok := raw.([]interface{}); ok && len(fp) > 0 && fp[0] != nil {
			return fmt.Errorf("instance_flexibility_policy is not supported on zonal instances.bulkInsert, which is the only API used by google_compute_bulk_instance")
		}
	}
	if raw := d.Get("workload_identity_config"); raw != nil {
		if wi, ok := raw.([]interface{}); ok && len(wi) > 0 && wi[0] != nil {
			return fmt.Errorf("workload_identity_config is not supported on instances.bulkInsert")
		}
	}
	if v, ok := d.GetOk("scheduling.0.location_hint"); ok && strings.TrimSpace(v.(string)) != "" {
		return fmt.Errorf("scheduling.location_hint is not supported on instances.bulkInsert (reserved for internal use on public API calls)")
	}
	if v, ok := d.GetOk("scheduling.0.instance_termination_action"); ok && v.(string) != "" {
		provisioningModel := d.Get("scheduling.0.provisioning_model").(string)
		if provisioningModel == "" || provisioningModel == "STANDARD" {
			return fmt.Errorf("instance_termination_action can only be used with Spot, Reservation-Bound or Flex Start provisioning models, not STANDARD. Either remove instance_termination_action or set provisioning_model to SPOT, SPOT_UNSPECIFIED, FLEX, or FLEX_START")
		}
	}
	return nil
}

func validateComputeBulkInstanceNamePattern(v interface{}, k string) (ws []string, errors []error) {
	pattern := v.(string)
	if !bulkInstanceNamePatternRe.MatchString(pattern) {
		errors = append(errors, fmt.Errorf("%q must contain exactly one continuous sequence of # characters, for example \"inst-####\"", k))
		return
	}

	match := bulkInstanceHashPlaceholderRe.FindStringIndex(pattern)
	if match == nil {
		errors = append(errors, fmt.Errorf("%q must contain at least one # character", k))
		return
	}
	if match[1]-match[0] > 18 {
		errors = append(errors, fmt.Errorf("%q can contain at most 18 consecutive # characters", k))
	}
	return
}

func validateBulkInsertRequestId(v interface{}, k string) (ws []string, es []error) {
	s, ok := v.(string)
	if !ok || s == "" {
		return
	}
	if _, err := uuid.Parse(s); err != nil {
		es = append(es, fmt.Errorf("%q must be a UUID (RFC 4122); the bulkInsert requestId query parameter rejects other formats: %v", k, err))
	}
	return
}

func cloneStringSlice(in []string) []string {
	if in == nil {
		return nil
	}
	out := make([]string, len(in))
	copy(out, in)
	return out
}

func cloneSchema(s *schema.Schema) *schema.Schema {
	if s == nil {
		return nil
	}

	cloned := *s
	cloned.AtLeastOneOf = cloneStringSlice(s.AtLeastOneOf)
	cloned.ConflictsWith = cloneStringSlice(s.ConflictsWith)
	cloned.ExactlyOneOf = cloneStringSlice(s.ExactlyOneOf)
	cloned.RequiredWith = cloneStringSlice(s.RequiredWith)

	switch elem := s.Elem.(type) {
	case *schema.Resource:
		elemClone := *elem
		elemClone.Schema = cloneSchemaMap(elem.Schema)
		cloned.Elem = &elemClone
	case *schema.Schema:
		cloned.Elem = cloneSchema(elem)
	default:
		cloned.Elem = s.Elem
	}

	return &cloned
}

func cloneSchemaMap(in map[string]*schema.Schema) map[string]*schema.Schema {
	out := make(map[string]*schema.Schema, len(in))
	for k, v := range in {
		out[k] = cloneSchema(v)
	}
	return out
}

func recurseOnSchemaForceNew(s map[string]*schema.Schema, f func(*schema.Schema)) {
	for _, field := range s {
		f(field)
		if e := field.Elem; e != nil {
			if r, ok := e.(*schema.Resource); ok {
				recurseOnSchemaForceNew(r.Schema, f)
			}
		}
	}
}

func deleteSchemaFieldPath(s map[string]*schema.Schema, parts ...string) {
	if len(parts) == 0 {
		return
	}

	if len(parts) == 1 {
		delete(s, parts[0])
		return
	}

	field, ok := s[parts[0]]
	if !ok || field.Elem == nil {
		return
	}

	child, ok := field.Elem.(*schema.Resource)
	if !ok {
		return
	}

	deleteSchemaFieldPath(child.Schema, parts[1:]...)
}

// filterSchemaConstraints removes references to excluded paths from AtLeastOneOf, ExactlyOneOf, etc.
// so provider validation passes after we delete fields not in Bulkinsert.api.
func filterSchemaConstraints(s map[string]*schema.Schema, excluded map[string]bool) {
	filter := func(attr []string) []string {
		if len(attr) == 0 {
			return attr
		}
		filtered := make([]string, 0, len(attr))
		for _, p := range attr {
			if !excluded[p] {
				filtered = append(filtered, p)
			}
		}
		return filtered
	}
	for _, field := range s {
		if field.AtLeastOneOf != nil {
			if f := filter(field.AtLeastOneOf); len(f) < len(field.AtLeastOneOf) {
				field.AtLeastOneOf = f
			}
		}
		if field.ExactlyOneOf != nil {
			if f := filter(field.ExactlyOneOf); len(f) < len(field.ExactlyOneOf) {
				field.ExactlyOneOf = f
			}
		}
		if field.RequiredWith != nil {
			if f := filter(field.RequiredWith); len(f) < len(field.RequiredWith) {
				field.RequiredWith = f
			}
		}
		if field.ConflictsWith != nil {
			if f := filter(field.ConflictsWith); len(f) < len(field.ConflictsWith) {
				field.ConflictsWith = f
			}
		}
		if e := field.Elem; e != nil {
			if r, ok := e.(*schema.Resource); ok {
				filterSchemaConstraints(r.Schema, excluded)
			}
		}
	}
}

func computeBulkInstanceSchema() map[string]*schema.Schema {
	s := cloneSchemaMap(ResourceComputeInstance().Schema)

	recurseOnSchemaForceNew(s, func(field *schema.Schema) {
		field.ForceNew = true
	})

	// Replace name with optional - expandComputeInstance needs it for internal use, we use name_pattern for bulk API
	s["name"] = &schema.Schema{
		Type:        schema.TypeString,
		Optional:    true,
		ForceNew:    true,
		Description: `Not used for bulk instances - use name_pattern or per_instance_properties keys instead. Kept for schema compatibility with expandComputeInstance.`,
	}

	// bulkInsert API does not support deletion_protection or enable_display.
	// Keep them in schema with defaults so expandComputeInstance does not panic; values are ignored.
	s["deletion_protection"] = &schema.Schema{
		Type:        schema.TypeBool,
		Optional:    true,
		ForceNew:    true,
		Description: `Not supported by bulk insert - always false. Kept for schema compatibility with expandComputeInstance.`,
	}
	s["enable_display"] = &schema.Schema{
		Type:        schema.TypeBool,
		Optional:    true,
		ForceNew:    true,
		Description: `Not supported by bulk insert - always false. Kept for schema compatibility with expandComputeInstance.`,
	}
	delete(s, "display_device")
	delete(s, "hostname")

	// bulkInsert should not expose inherited instance output/state fields.
	// Note: boot_disk.initialize_params.architecture is input (API), not output-only.
	// Also remove beta-only fields not in Bulkinsert.api: mac_address, security_policy (network-level),
	// partner_metadata, graceful_shutdown, maintenance_interval, preemption_notice_duration.
	for _, fieldPath := range [][]string{
		{"attached_disk", "disk_encryption_key_raw"},
		{"attached_disk", "disk_encryption_key_rsa"},
		{"attached_disk", "disk_encryption_key_sha256"},
		{"boot_disk", "disk_encryption_key_raw"},
		{"boot_disk", "disk_encryption_key_rsa"},
		{"boot_disk", "disk_encryption_key_sha256"},
		{"boot_disk", "initialize_params", "source_image_encryption_key", "raw_key"},
		{"boot_disk", "initialize_params", "source_image_encryption_key", "rsa_encrypted_key"},
		{"boot_disk", "initialize_params", "source_image_encryption_key", "sha256"},
		{"network_interface", "ipv6_access_type"},
		{"network_interface", "name"},
		{"network_interface", "mac_address"},
		{"network_interface", "security_policy"},
		{"network_interface", "enable_vpc_scoped_dns"},
		{"partner_metadata"},
		{"scheduling", "graceful_shutdown"},
		{"scheduling", "maintenance_interval"},
		{"scheduling", "preemption_notice_duration"},
		{"cpu_platform"},
		{"creation_timestamp"},
		{"current_status"},
		{"desired_status"},
		{"instance_encryption_key"},
		{"instance_id"},
		{"label_fingerprint"},
		{"metadata_fingerprint"},
		{"self_link"},
		{"tags_fingerprint"},
	} {
		deleteSchemaFieldPath(s, fieldPath...)
	}

	filterSchemaConstraints(s, map[string]bool{
		"boot_disk.0.disk_encryption_key_raw":                         true,
		"boot_disk.0.disk_encryption_key_rsa":                         true,
		"scheduling.0.maintenance_interval":                           true,
		"scheduling.0.graceful_shutdown":                              true,
		"scheduling.0.preemption_notice_duration": true,
	})

	// When source_instance_template is used, boot_disk/machine_type/network_interface are optional overrides
	for _, field := range []string{"boot_disk", "machine_type", "network_interface"} {
		if sch, ok := s[field]; ok {
			sch.Required = false
			sch.Optional = true
		}
	}

	if schedulingSchema, ok := s["scheduling"]; ok && schedulingSchema.Elem != nil {
		if schedulingResource, ok := schedulingSchema.Elem.(*schema.Resource); ok {
			schedulingResource.Schema["location_hint"] = &schema.Schema{
				Type:        schema.TypeString,
				Optional:    true,
				ForceNew:    true,
				Description: `Not supported on instances.bulkInsert; if set, plan fails (reserved for internal use on public API calls).`,
			}
		}
	}

	s["private_ipv6_google_access"] = &schema.Schema{
		Type:        schema.TypeString,
		Optional:    true,
		ForceNew:    true,
		Description: `The private IPv6 Google access type for VMs.`,
	}
	s["workload_identity_config"] = &schema.Schema{
		Type:        schema.TypeList,
		Optional:    true,
		ForceNew:    true,
		MaxItems:    1,
		Description: `Not supported on instances.bulkInsert; if set, plan fails. Use google_compute_instance if you need workload identity.`,
		Elem: &schema.Resource{
			Schema: map[string]*schema.Schema{
				"identity": {
					Type:        schema.TypeString,
					Optional:    true,
					ForceNew:    true,
					Description: `The workload identity attached to the instance.`,
				},
				"identity_certificate_enabled": {
					Type:        schema.TypeBool,
					Optional:    true,
					ForceNew:    true,
					Description: `Whether workload identity certificates are enabled.`,
				},
			},
		},
	}

	s["name_pattern"] = &schema.Schema{
		Type:        schema.TypeString,
		Optional:    true,
		ForceNew:    true,
		ValidateFunc: validateComputeBulkInstanceNamePattern,
		Description: `The string pattern used for the names of the VMs. The pattern must contain one continuous sequence of placeholder hash characters (#) with each character corresponding to one digit of the generated instance name. Example: "inst-####" generates instance names such as "inst-0001" and "inst-0002".`,
	}
	s["per_instance_properties"] = &schema.Schema{
		Type:        schema.TypeMap,
		Optional:    true,
		ForceNew:    true,
		Elem:        &schema.Schema{Type: schema.TypeString},
		Description: `Per-instance properties keyed by explicit instance name. The map value sets the custom hostname for that instance; use an empty string to request a specific name without a custom hostname.`,
	}
	s["instance_count"] = &schema.Schema{
		Type:        schema.TypeInt,
		Required:    true,
		ForceNew:    true,
		Description: `The number of instances to create.`,
	}
	s["min_count"] = &schema.Schema{
		Type:        schema.TypeInt,
		Optional:    true,
		ForceNew:    true,
		Description: `The minimum number of instances to create. If not specified, instance_count is used as the default. If min_count instances cannot be created, no instances will be created and any already created will be deleted.`,
	}
	s["source_instance_template"] = &schema.Schema{
		Type:        schema.TypeString,
		Optional:    true,
		ForceNew:    true,
		Description: `Name or self link of an instance template to create the instances based on. If provided, instance_properties can override specific values.`,
	}
	s["request_id"] = &schema.Schema{
		Type:         schema.TypeString,
		Optional:     true,
		ForceNew:     true,
		ValidateFunc: validateBulkInsertRequestId,
		Description:  `An optional request ID (RFC 4122 UUID) for the bulkInsert requestId query parameter; required format when set.`,
	}
	s["location_policy"] = &schema.Schema{
		Type:        schema.TypeList,
		Optional:    true,
		ForceNew:    true,
		MaxItems:    1,
		Description: `Not supported on zonal instances.bulkInsert; if set, plan fails. This resource only calls the zonal bulk insert API.`,
		Elem: &schema.Resource{
			Schema: map[string]*schema.Schema{
				"target_shape": {
					Type:        schema.TypeString,
					Optional:    true,
					ForceNew:    true,
					Description: `Strategy for distributing VMs across zones.`,
				},
				"location": {
					Type:        schema.TypeList,
					Optional:    true,
					ForceNew:    true,
					Description: `Per-zone preferences and constraints keyed by zone URL.`,
					Elem: &schema.Resource{
						Schema: map[string]*schema.Schema{
							"zone": {
								Type:        schema.TypeString,
								Required:    true,
								ForceNew:    true,
								Description: `The zone URL, for example zones/us-central1-a.`,
							},
							"preference": {
								Type:        schema.TypeString,
								Optional:    true,
								ForceNew:    true,
								Description: `Preference for this zone. Supported values are ALLOW and DENY.`,
							},
							"max_count": {
								Type:        schema.TypeInt,
								Optional:    true,
								ForceNew:    true,
								Description: `Maximum number of instances allowed in this zone.`,
							},
						},
					},
				},
				"zones": {
					Type:        schema.TypeList,
					Optional:    true,
					ForceNew:    true,
					Description: `Explicit zones to include in the location policy.`,
					Elem: &schema.Resource{
						Schema: map[string]*schema.Schema{
							"zone": {
								Type:        schema.TypeString,
								Required:    true,
								ForceNew:    true,
								Description: `The zone URL, for example zones/us-central1-a.`,
							},
						},
					},
				},
			},
		},
	}
	s["instance_flexibility_policy"] = &schema.Schema{
		Type:        schema.TypeList,
		Optional:    true,
		ForceNew:    true,
		MaxItems:    1,
		Description: `Not supported on zonal instances.bulkInsert; if set, plan fails. This resource only calls the zonal bulk insert API.`,
		Elem: &schema.Resource{
			Schema: map[string]*schema.Schema{
				"instance_selection": {
					Type:        schema.TypeList,
					Optional:    true,
					ForceNew:    true,
					Description: `Alternative machine type selections ordered by rank.`,
					Elem: &schema.Resource{
						Schema: map[string]*schema.Schema{
							"name": {
								Type:        schema.TypeString,
								Required:    true,
								ForceNew:    true,
								Description: `An arbitrary RFC1035 identifier for this instance selection.`,
							},
							"machine_types": {
								Type:        schema.TypeList,
								Required:    true,
								ForceNew:    true,
								Elem:        &schema.Schema{Type: schema.TypeString},
								Description: `Alternative machine types to use for this selection.`,
							},
							"rank": {
								Type:        schema.TypeInt,
								Optional:    true,
								ForceNew:    true,
								Description: `Priority for this selection. Lower ranks are considered first.`,
							},
							"disk": {
								Type:        schema.TypeList,
								Optional:    true,
								ForceNew:    true,
								Description: `Existing disks to attach for this selection (overrides instanceProperties disks when this selection is chosen).`,
								Elem: &schema.Resource{
									Schema: map[string]*schema.Schema{
										"source": {
											Type:        schema.TypeString,
											Required:    true,
											ForceNew:    true,
											Description: `URL or name of the existing persistent disk.`,
										},
										"mode": {
											Type:        schema.TypeString,
											Optional:    true,
											ForceNew:    true,
											Description: `READ_WRITE or READ_ONLY.`,
										},
										"device_name": {
											Type:        schema.TypeString,
											Optional:    true,
											ForceNew:    true,
											Description: `Device name exposed to the guest OS.`,
										},
										"force_attach": {
											Type:        schema.TypeBool,
											Optional:    true,
											ForceNew:    true,
											Description: `Attach even if the disk is already attached to another resource.`,
