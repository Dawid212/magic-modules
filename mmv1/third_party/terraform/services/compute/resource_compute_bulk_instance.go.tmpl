func resourceComputeBulkInstanceCreate(d *schema.ResourceData, meta interface{}) error {
	config := meta.(*transport_tpg.Config)
	userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
	if err != nil {
		return err
	}

	project, err := tpgresource.GetProject(d, config)
	if err != nil {
		return err
	}

	z, err := tpgresource.GetZone(d, config)
	if err != nil {
		return err
	}

	bulkReq := &compute.BulkInsertInstanceResource{
		Count:       int64(d.Get("instance_count").(int)),
		NamePattern: d.Get("name_pattern").(string),
	}
	explicitNames := configuredBulkPerInstanceNames(d)
	if perInstanceProperties := expandBulkInstancePerInstanceProperties(d); len(perInstanceProperties) > 0 {
		bulkReq.PerInstanceProperties = perInstanceProperties
	}

	if v, ok := d.GetOk("min_count"); ok {
		bulkReq.MinCount = int64(v.(int))
	}

	if v, ok := d.GetOk("source_instance_template"); ok {
		sourceTemplate := v.(string)
		tpl, err := tpgresource.ParseInstanceTemplateFieldValue(sourceTemplate, d, config)
		if err != nil {
			return err
		}
		bulkReq.SourceInstanceTemplate = tpl.RelativeLink()
	}

	if locationPolicy := expandBulkInsertLocationPolicy(d); locationPolicy != nil {
		bulkReq.LocationPolicy = locationPolicy
	}

	instanceFlexibilityPolicy, err := expandBulkInsertInstanceFlexibilityPolicy(d, config)
	if err != nil {
		return err
	}
	if instanceFlexibilityPolicy != nil {
		bulkReq.InstanceFlexibilityPolicy = instanceFlexibilityPolicy
	}

	if bulkReq.SourceInstanceTemplate == "" {
		if _, hasBootDisk := d.GetOk("boot_disk"); !hasBootDisk {
			return fmt.Errorf("either boot_disk (with machine_type, network_interface) or source_instance_template is required")
		}
		instanceProperties, err := expandComputeInstancePropertiesForBulkInsert(project, d, config)
		if err != nil {
			return err
		}
		bulkReq.InstanceProperties = instanceProperties
	} else {
		// When using a source template, only send explicitly configured overrides.
		// This preserves bulkInsert JSON Merge Patch semantics and avoids injecting
		// instance-schema defaults like scheduling.automatic_restart.
		instanceProperties, err := expandComputeInstancePropertyOverridesForBulkInsert(project, d, config)
		if err != nil {
			return err
		}
		bulkReq.InstanceProperties = instanceProperties
	}

	requestURL, err := tpgresource.ReplaceVars(d, config, "{{"{{"}}ComputeBasePath{{"}}"}}projects/{{"{{"}}project{{"}}"}}/zones/{{"{{"}}zone{{"}}"}}/instances/bulkInsert")
	if err != nil {
		return err
	}
	if v, ok := d.GetOk("request_id"); ok {
		requestID := v.(string)
		if requestID != "" {
			requestURL = fmt.Sprintf("%s?requestId=%s", requestURL, neturl.QueryEscape(requestID))
		}
	}

	body, err := json.Marshal(bulkReq)
	if err != nil {
		return fmt.Errorf("Error marshaling bulk insert request: %s", err)
	}

	var bodyMap map[string]interface{}
	if err := json.Unmarshal(body, &bodyMap); err != nil {
		return fmt.Errorf("Error converting bulk insert request to map: %s", err)
	}

	log.Printf("[INFO] Requesting bulk instance creation with count=%d, name_pattern=%s, explicit_names=%d", bulkReq.Count, bulkReq.NamePattern, len(explicitNames))

	res, err := transport_tpg.SendRequest(transport_tpg.SendRequestOptions{
		Config:    config,
		Method:    "POST",
		Project:   project,
		RawURL:    requestURL,
		UserAgent: userAgent,
		Body:      bodyMap,
		Timeout:   d.Timeout(schema.TimeoutCreate),
	})
	if err != nil {
		return fmt.Errorf("Error creating bulk instances: %s", err)
	}

	err = ComputeOperationWaitTime(config, res, project, "bulk instances to create", userAgent, d.Timeout(schema.TimeoutCreate))
	if err != nil {
		return err
	}

	createdInstances, err := listTrackedBulkInstances(config, project, z, bulkReq.NamePattern, explicitNames, userAgent)
	if err != nil {
		return fmt.Errorf("Error listing created bulk instances: %s", err)
	}
	if len(createdInstances) == 0 {
		return fmt.Errorf("bulkInsert completed but no created instances were found")
	}
	d.SetId(bulkInstanceResourceID(project, z, bulkReq.NamePattern, sortedBulkInstanceNames(createdInstances)))
	if err := setBulkInstanceState(d, createdInstances); err != nil {
		d.SetId("")
		return err
	}

	return resourceComputeBulkInstanceRead(d, meta)
}

func resourceComputeBulkInstanceRead(d *schema.ResourceData, meta interface{}) error {
	config := meta.(*transport_tpg.Config)
	userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
	if err != nil {
		return err
	}

	project, err := tpgresource.GetProject(d, config)
	if err != nil {
		return err
	}

	z, err := tpgresource.GetZone(d, config)
	if err != nil {
		return err
	}

	namePattern := d.Get("name_pattern").(string)
	stateNames := expandBulkInstanceStateNames(d)
	explicitNames := configuredBulkPerInstanceNames(d)
	if len(explicitNames) == 0 && len(stateNames) > 0 {
		explicitNames = stateNames
	}
	expectedCount := d.Get("instance_count").(int)
	matchingInstances, err := listTrackedBulkInstances(config, project, z, namePattern, explicitNames, userAgent)
	if err != nil {
		return fmt.Errorf("Error listing instances: %s", err)
	}

	currentInstances := matchingInstances
	if len(stateNames) > 0 {
		matchingByName := make(map[string]*compute.Instance, len(matchingInstances))
		for _, inst := range matchingInstances {
			matchingByName[inst.Name] = inst
		}

		currentInstances = make([]*compute.Instance, 0, len(stateNames))
		for _, name := range stateNames {
			if inst, ok := matchingByName[name]; ok {
				currentInstances = append(currentInstances, inst)
			}
		}
	}

	if len(currentInstances) == 0 {
		log.Printf("[WARN] No tracked bulk instances found - resource may have been deleted")
		d.SetId("")
		return nil
	}

	if len(currentInstances) != expectedCount {
		log.Printf("[WARN] Expected %d tracked bulk instances, found %d", expectedCount, len(currentInstances))
	}

	if err := setBulkInstanceState(d, currentInstances); err != nil {
		return err
	}
	return nil
}

func resourceComputeBulkInstanceDelete(d *schema.ResourceData, meta interface{}) error {
	config := meta.(*transport_tpg.Config)
	userAgent, err := tpgresource.GenerateUserAgentString(d, config.UserAgent)
	if err != nil {
		return err
	}

	project, err := tpgresource.GetProject(d, config)
	if err != nil {
		return err
	}

	z, err := tpgresource.GetZone(d, config)
	if err != nil {
		return err
	}

	instanceNames := expandBulkInstanceStateNames(d)
	if len(instanceNames) == 0 {
		matchingInstances, err := listTrackedBulkInstances(config, project, z, d.Get("name_pattern").(string), configuredBulkPerInstanceNames(d), userAgent)
		if err != nil {
			return fmt.Errorf("Error listing instances for deletion: %s", err)
		}
		instanceNames = sortedBulkInstanceNames(matchingInstances)
	}

	for _, name := range instanceNames {
		log.Printf("[INFO] Deleting instance %s", name)
		op, err := config.NewComputeClient(userAgent).Instances.Delete(project, z, name).Do()
		if err != nil {
			if gerr, ok := err.(*googleapi.Error); ok && gerr.Code == 404 {
				continue
			}
			return fmt.Errorf("Error deleting instance %s: %s", name, err)
		}
		err = ComputeOperationWaitTime(config, op, project, "instance to delete", userAgent, d.Timeout(schema.TimeoutDelete))
		if err != nil {
			return fmt.Errorf("Error waiting for instance %s to delete: %s", name, err)
		}
	}

	d.SetId("")
	return nil
}

func expandComputeInstancePropertiesForBulkInsert(project string, d *schema.ResourceData, config *transport_tpg.Config) (*compute.InstanceProperties, error) {
	var machineTypeURL string
	if mt, ok := d.GetOk("machine_type"); ok {
		machineType, err := tpgresource.ParseMachineTypesFieldValue(mt.(string), d, config)
		if err != nil {
			return nil, fmt.Errorf("Error loading machine type: %s", err)
		}
		machineTypeURL = machineType.RelativeLink()
	}

	disks := []*compute.AttachedDisk{}
	if _, hasBootDisk := d.GetOk("boot_disk"); hasBootDisk {
		bootDisk, err := expandBootDisk(d, config, project)
		if err != nil {
			return nil, err
		}
		disks = append(disks, bootDisk)
	}
	if _, hasScratchDisk := d.GetOk("scratch_disk"); hasScratchDisk {
		scratchDisks, err := expandScratchDisks(d, config, project)
		if err != nil {
			return nil, err
		}
		disks = append(disks, scratchDisks...)
	}
	attachedDisksCount := d.Get("attached_disk.#").(int)
	for i := 0; i < attachedDisksCount; i++ {
		diskConfig := d.Get(fmt.Sprintf("attached_disk.%d", i)).(map[string]interface{})
		disk, err := expandAttachedDisk(diskConfig, d, config)
		if err != nil {
			return nil, err
		}
		disks = append(disks, disk)
	}

	scheduling, err := expandScheduling(d.Get("scheduling"))
	if err != nil {
		return nil, fmt.Errorf("Error creating scheduling: %s", err)
	}
	setBulkInsertSchedulingLocationHint(d, scheduling)
	if scheduling != nil && scheduling.ProvisioningModel == "SPOT" {
		// bulkInsert rejects SPOT when the inherited scheduling helper serializes
		// the instance-schema default of preemptible=false.
		scheduling.Preemptible = true
		scheduling.AutomaticRestart = googleapi.Bool(false)
		scheduling.OnHostMaintenance = "TERMINATE"
		scheduling.ForceSendFields = append(
			scheduling.ForceSendFields,
			"Preemptible",
			"AutomaticRestart",
			"OnHostMaintenance",
		)
	}
	params, err := expandParams(d)
	if err != nil {
		return nil, fmt.Errorf("Error creating params: %s", err)
	}
	metadata, err := expandBulkInsertMetadata(d)
	if err != nil {
		return nil, fmt.Errorf("Error creating metadata: %s", err)
	}
	networkInterfaces, err := expandNetworkInterfaces(d, config)
	if err != nil {
		return nil, fmt.Errorf("Error creating network interfaces: %s", err)
	}
	networkPerformanceConfig, err := expandNetworkPerformanceConfig(d, config)
	if err != nil {
		return nil, fmt.Errorf("Error creating network performance config: %s", err)
	}
	accels, err := expandInstanceGuestAccelerators(d, config)
	if err != nil {
		return nil, fmt.Errorf("Error creating guest accelerators: %s", err)
	}
	accels = sanitizeBulkInsertGuestAccelerators(accels)
	reservationAffinity, err := expandReservationAffinity(d)
	if err != nil {
		return nil, fmt.Errorf("Error creating reservation affinity: %s", err)
	}

	// Machine type for bulkInsert must be name only, not full URL
	machineType := tpgresource.GetResourceNameFromSelfLink(machineTypeURL)
	if machineType == "" {
		machineType = machineTypeURL
	}

	props := &compute.InstanceProperties{
		CanIpForward:               d.Get("can_ip_forward").(bool),
		Description:                d.Get("description").(string),
		Disks:                      sanitizeBulkInsertDisks(disks),
		MachineType:                machineType,
		Metadata:                   metadata,
		NetworkInterfaces:          networkInterfaces,
		NetworkPerformanceConfig:   networkPerformanceConfig,
		Tags:                       expandBulkInsertTags(d),
		Labels:                     tpgresource.ExpandEffectiveLabels(d),
		ServiceAccounts:            expandBulkInsertServiceAccounts(d),
		GuestAccelerators:          accels,
		MinCpuPlatform:             d.Get("min_cpu_platform").(string),
		Scheduling:                 scheduling,
		ConfidentialInstanceConfig: expandConfidentialInstanceConfig(d),
		AdvancedMachineFeatures:    expandAdvancedMachineFeatures(d),
		ShieldedInstanceConfig:     expandShieldedVmConfigs(d),
		ResourcePolicies:           sanitizeBulkInsertResourcePolicies(tpgresource.ConvertStringArr(d.Get("resource_policies").([]interface{}))),
		ReservationAffinity:        reservationAffinity,
		KeyRevocationActionType:    d.Get("key_revocation_action_type").(string),
	}
	if v, ok := d.GetOkExists("private_ipv6_google_access"); ok {
		props.PrivateIpv6GoogleAccess = v.(string)
		props.ForceSendFields = append(props.ForceSendFields, "PrivateIpv6GoogleAccess")
	}
	if workloadIdentityConfig := expandBulkInsertWorkloadIdentityConfig(d); workloadIdentityConfig != nil {
		props.WorkloadIdentityConfig = workloadIdentityConfig
	}
	if params != nil && params.ResourceManagerTags != nil {
		props.ResourceManagerTags = params.ResourceManagerTags
	}
	return props, nil
}

func expandComputeInstancePropertyOverridesForBulkInsert(project string, d *schema.ResourceData, config *transport_tpg.Config) (*compute.InstanceProperties, error) {
	props := &compute.InstanceProperties{}
	hasOverrides := false

	if rawConfigHasTopLevelAttr(d, "machine_type") {
		machineType, err := tpgresource.ParseMachineTypesFieldValue(d.Get("machine_type").(string), d, config)
		if err != nil {
			return nil, fmt.Errorf("Error loading machine type: %s", err)
		}
		props.MachineType = tpgresource.GetResourceNameFromSelfLink(machineType.RelativeLink())
		hasOverrides = true
	}

	disks := []*compute.AttachedDisk{}
	if _, ok := d.GetOk("boot_disk"); ok {
		bootDisk, err := expandBootDisk(d, config, project)
		if err != nil {
			return nil, err
		}
		disks = append(disks, bootDisk)
	}
	if _, ok := d.GetOk("scratch_disk"); ok {
		scratchDisks, err := expandScratchDisks(d, config, project)
		if err != nil {
			return nil, err
		}
		disks = append(disks, scratchDisks...)
	}
	if _, ok := d.GetOk("attached_disk"); ok {
		attachedDisksCount := d.Get("attached_disk.#").(int)
		for i := 0; i < attachedDisksCount; i++ {
			diskConfig := d.Get(fmt.Sprintf("attached_disk.%d", i)).(map[string]interface{})
			disk, err := expandAttachedDisk(diskConfig, d, config)
			if err != nil {
				return nil, err
			}
			disks = append(disks, disk)
		}
	}
	if len(disks) > 0 {
		props.Disks = sanitizeBulkInsertDisks(disks)
		hasOverrides = true
	}

	if rawConfigHasTopLevelAttr(d, "can_ip_forward") {
		props.CanIpForward = d.Get("can_ip_forward").(bool)
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "description") {
		props.Description = d.Get("description").(string)
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "metadata") || rawConfigHasTopLevelAttr(d, "metadata_startup_script") {
		metadata, err := expandBulkInsertMetadata(d)
		if err != nil {
			return nil, fmt.Errorf("Error creating metadata: %s", err)
		}
		props.Metadata = metadata
		hasOverrides = true
	}
	if _, ok := d.GetOk("network_interface"); ok {
		networkInterfaces, err := expandNetworkInterfaces(d, config)
		if err != nil {
			return nil, fmt.Errorf("Error creating network interfaces: %s", err)
		}
		props.NetworkInterfaces = networkInterfaces
		hasOverrides = true
	}
	if _, ok := d.GetOk("network_performance_config"); ok {
		networkPerformanceConfig, err := expandNetworkPerformanceConfig(d, config)
		if err != nil {
			return nil, fmt.Errorf("Error creating network performance config: %s", err)
		}
		props.NetworkPerformanceConfig = networkPerformanceConfig
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "tags") {
		props.Tags = expandBulkInsertTags(d)
		hasOverrides = true
	}
	if labels := tpgresource.ExpandEffectiveLabels(d); len(labels) > 0 {
		props.Labels = labels
		hasOverrides = true
	}
	if _, ok := d.GetOk("service_account"); ok {
		props.ServiceAccounts = expandBulkInsertServiceAccounts(d)
		hasOverrides = true
	}
	if _, ok := d.GetOk("guest_accelerator"); ok {
		accels, err := expandInstanceGuestAccelerators(d, config)
		if err != nil {
			return nil, fmt.Errorf("Error creating guest accelerators: %s", err)
		}
		props.GuestAccelerators = sanitizeBulkInsertGuestAccelerators(accels)
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "min_cpu_platform") {
		props.MinCpuPlatform = d.Get("min_cpu_platform").(string)
		hasOverrides = true
	}
	if _, ok := d.GetOk("scheduling"); ok {
		scheduling, err := expandScheduling(d.Get("scheduling"))
		if err != nil {
			return nil, fmt.Errorf("Error creating scheduling: %s", err)
		}
		setBulkInsertSchedulingLocationHint(d, scheduling)
		if scheduling != nil && scheduling.ProvisioningModel == "SPOT" {
			scheduling.Preemptible = true
			scheduling.AutomaticRestart = googleapi.Bool(false)
			scheduling.OnHostMaintenance = "TERMINATE"
			scheduling.ForceSendFields = append(
				scheduling.ForceSendFields,
				"Preemptible",
				"AutomaticRestart",
				"OnHostMaintenance",
			)
		}
		props.Scheduling = scheduling
		hasOverrides = true
	}
	if _, ok := d.GetOk("confidential_instance_config"); ok {
		props.ConfidentialInstanceConfig = expandConfidentialInstanceConfig(d)
		hasOverrides = true
	}
	if _, ok := d.GetOk("advanced_machine_features"); ok {
		props.AdvancedMachineFeatures = expandAdvancedMachineFeatures(d)
		hasOverrides = true
	}
	if _, ok := d.GetOk("shielded_instance_config"); ok {
		props.ShieldedInstanceConfig = expandShieldedVmConfigs(d)
		hasOverrides = true
	}
	if _, ok := d.GetOk("resource_policies"); ok {
		props.ResourcePolicies = sanitizeBulkInsertResourcePolicies(tpgresource.ConvertStringArr(d.Get("resource_policies").([]interface{})))
		hasOverrides = true
	}
	if _, ok := d.GetOk("reservation_affinity"); ok {
		reservationAffinity, err := expandReservationAffinity(d)
		if err != nil {
			return nil, fmt.Errorf("Error creating reservation affinity: %s", err)
		}
		props.ReservationAffinity = reservationAffinity
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "key_revocation_action_type") {
		props.KeyRevocationActionType = d.Get("key_revocation_action_type").(string)
		hasOverrides = true
	}
	if rawConfigHasTopLevelAttr(d, "private_ipv6_google_access") {
		props.PrivateIpv6GoogleAccess = d.Get("private_ipv6_google_access").(string)
		props.ForceSendFields = append(props.ForceSendFields, "PrivateIpv6GoogleAccess")
		hasOverrides = true
	}
	if _, ok := d.GetOk("workload_identity_config"); ok {
		props.WorkloadIdentityConfig = expandBulkInsertWorkloadIdentityConfig(d)
		hasOverrides = true
	}
	if _, ok := d.GetOk("params"); ok {
		params, err := expandParams(d)
		if err != nil {
			return nil, fmt.Errorf("Error creating params: %s", err)
		}
		if params != nil && params.ResourceManagerTags != nil {
			props.ResourceManagerTags = params.ResourceManagerTags
			hasOverrides = true
		}
	}

	if !hasOverrides {
		return nil, nil
	}

	return props, nil
}
