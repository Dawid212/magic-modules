func bulkRunInstanceCheck(instance *compute.Instance, check resource.TestCheckFunc) error {
	if check == nil {
		return nil
	}
	return check(nil)
}

func testAccCheckComputeBulkInstanceFullInstanceAPI(instance *compute.Instance) error {
	if instance == nil {
		return fmt.Errorf("instance is nil")
	}
	for _, chk := range []resource.TestCheckFunc{
		testAccCheckComputeInstanceTag(instance, "bulk"),
		testAccCheckComputeInstanceTag(instance, "acctest"),
		testAccCheckComputeInstanceLabel(instance, "environment", "test"),
		testAccCheckComputeInstanceLabel(instance, "suite", "bulk"),
		testAccCheckComputeInstanceMetadata(instance, "foo", "bar"),
		testAccCheckComputeInstanceAccessConfigHasNatIP(instance),
	} {
		if err := bulkRunInstanceCheck(instance, chk); err != nil {
			return err
		}
	}
	if err := testAccCheckComputeBulkInstanceHasMachineType("n2-standard-2")(instance); err != nil {
		return err
	}
	if !instance.CanIpForward {
		return fmt.Errorf("expected CanIpForward true")
	}
	if instance.Description != "Acceptance test coverage for bulk instances" {
		return fmt.Errorf("description: got %q", instance.Description)
	}
	if !strings.Contains(instance.MinCpuPlatform, "Cascade") {
		return fmt.Errorf("MinCpuPlatform: expected Intel Cascade Lake family, got %q", instance.MinCpuPlatform)
	}
	if instance.ShieldedInstanceConfig == nil || !instance.ShieldedInstanceConfig.EnableVtpm ||
		instance.ShieldedInstanceConfig.EnableSecureBoot || !instance.ShieldedInstanceConfig.EnableIntegrityMonitoring {
		return fmt.Errorf("ShieldedInstanceConfig: %#v", instance.ShieldedInstanceConfig)
	}
	if instance.AdvancedMachineFeatures == nil || !instance.AdvancedMachineFeatures.EnableNestedVirtualization ||
		instance.AdvancedMachineFeatures.ThreadsPerCore != 1 {
		return fmt.Errorf("AdvancedMachineFeatures: %#v", instance.AdvancedMachineFeatures)
	}
	if instance.NetworkPerformanceConfig == nil || instance.NetworkPerformanceConfig.TotalEgressBandwidthTier != "DEFAULT" {
		return fmt.Errorf("NetworkPerformanceConfig: %#v", instance.NetworkPerformanceConfig)
	}
	if len(instance.NetworkInterfaces) < 1 || instance.NetworkInterfaces[0].NicType != "GVNIC" {
		return fmt.Errorf("expected GVNIC on first NIC, got %#v", instance.NetworkInterfaces)
	}
	if instance.ReservationAffinity == nil || instance.ReservationAffinity.ConsumeReservationType != "NO_RESERVATION" {
		return fmt.Errorf("ReservationAffinity: %#v", instance.ReservationAffinity)
	}
	if instance.KeyRevocationActionType != "NONE" {
		return fmt.Errorf("KeyRevocationActionType: want NONE, got %q", instance.KeyRevocationActionType)
	}
	return nil
}

func testAccCheckComputeBulkInstanceExists(t *testing.T, name string, wantCount int) resource.TestCheckFunc {
	return func(s *terraform.State) error {
		rs, ok := s.RootModule().Resources[name]
		if !ok {
			return fmt.Errorf("not found: %s", name)
		}

		if rs.Primary.ID == "" {
			return fmt.Errorf("no ID is set for %s", name)
		}

		instances, err := testAccListComputeBulkInstances(t, rs.Primary.Attributes["project"], rs.Primary.Attributes["zone"], rs.Primary.Attributes["name_pattern"], testAccComputeBulkInstanceStateNames(rs.Primary.Attributes))
		if err != nil {
			return err
		}

		if len(instances) != wantCount {
			names := make([]string, 0, len(instances))
			for _, instance := range instances {
				names = append(names, instance.Name)
			}
			return fmt.Errorf("expected %d instances for %s, got %d: %v", wantCount, name, len(instances), names)
		}

		return nil
	}
}

func testAccCheckComputeBulkInstanceFirstInstance(t *testing.T, name string, check func(*compute.Instance) error) resource.TestCheckFunc {
	return func(s *terraform.State) error {
		rs, ok := s.RootModule().Resources[name]
		if !ok {
			return fmt.Errorf("not found: %s", name)
		}

		instances, err := testAccListComputeBulkInstances(t, rs.Primary.Attributes["project"], rs.Primary.Attributes["zone"], rs.Primary.Attributes["name_pattern"], testAccComputeBulkInstanceStateNames(rs.Primary.Attributes))
		if err != nil {
			return err
		}
		if len(instances) == 0 {
			return fmt.Errorf("no instances found for %s", name)
