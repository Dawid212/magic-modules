func TestAccComputeBulkInstance_attachedDiskForceAttach(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{
		"random_suffix": acctest.RandString(t, 10),
	}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckComputeBulkInstanceDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccComputeBulkInstance_attachedDiskForceAttach(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr("google_compute_bulk_instance.attached_disk", "current_instance_count", "1"),
					resource.TestCheckResourceAttr("google_compute_bulk_instance.attached_disk", "instance_names.#", "1"),
					testAccCheckComputeBulkInstanceExists(t, "google_compute_bulk_instance.attached_disk", 1),
					testAccCheckComputeBulkInstanceFirstInstance(t, "google_compute_bulk_instance.attached_disk", func(instance *compute.Instance) error {
						var dataDisk *compute.AttachedDisk
						for _, d := range instance.Disks {
							if d != nil && d.DeviceName == "data-disk" {
								dataDisk = d
								break
							}
						}
						if dataDisk == nil {
							return fmt.Errorf("expected attached disk device_name data-disk on instance, got %#v", instance.Disks)
						}
						// force_attach is input-only in the API and may be omitted on instances.get.
						if dataDisk.Mode != "READ_ONLY" {
							return fmt.Errorf("expected READ_ONLY attached disk, got %q", dataDisk.Mode)
						}
						return nil
					}),
				),
			},
		},
	})
}

