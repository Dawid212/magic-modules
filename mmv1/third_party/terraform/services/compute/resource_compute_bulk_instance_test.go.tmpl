		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckComputeBulkInstanceDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccComputeBulkInstance_advancedMachineFeaturesExpanded(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr("google_compute_bulk_instance.advanced_machine_features", "current_instance_count", "1"),
					resource.TestCheckResourceAttr("google_compute_bulk_instance.advanced_machine_features", "instance_names.#", "1"),
					testAccCheckComputeBulkInstanceExists(t, "google_compute_bulk_instance.advanced_machine_features", 1),
					testAccCheckComputeBulkInstanceFirstInstance(t, "google_compute_bulk_instance.advanced_machine_features", func(instance *compute.Instance) error {
						if err := testAccCheckComputeBulkInstanceHasMachineType("c4-standard-2")(instance); err != nil {
							return err
						}
						amf := instance.AdvancedMachineFeatures
						if amf == nil {
							return fmt.Errorf("expected advanced_machine_features on API instance")
						}
						if !amf.EnableNestedVirtualization {
							return fmt.Errorf("expected EnableNestedVirtualization true, got %#v", amf)
						}
						if amf.ThreadsPerCore != 1 {
							return fmt.Errorf("expected ThreadsPerCore 1, got %d", amf.ThreadsPerCore)
						}
						if amf.TurboMode != "ALL_CORE_MAX" {
							return fmt.Errorf("expected TurboMode ALL_CORE_MAX, got %q", amf.TurboMode)
						}
						if amf.VisibleCoreCount != 1 {
							return fmt.Errorf("expected VisibleCoreCount 1, got %d", amf.VisibleCoreCount)
						}
						return nil
					}),
				),
			},
		},
	})
}

func TestAccComputeBulkInstance_spot(t *testing.T) {
	t.Parallel()

	context := map[string]interface{}{
		"random_suffix": acctest.RandString(t, 10),
	}

	acctest.VcrTest(t, resource.TestCase{
		PreCheck:                 func() { acctest.AccTestPreCheck(t) },
		ProtoV5ProviderFactories: acctest.ProtoV5ProviderFactories(t),
		CheckDestroy:             testAccCheckComputeBulkInstanceDestroyProducer(t),
		Steps: []resource.TestStep{
			{
				Config: testAccComputeBulkInstance_spot(context),
				Check: resource.ComposeTestCheckFunc(
					resource.TestCheckResourceAttr("google_compute_bulk_instance.spot", "current_instance_count", "1"),
					resource.TestCheckResourceAttr("google_compute_bulk_instance.spot", "instance_names.#", "1"),
					testAccCheckComputeBulkInstanceExists(t, "google_compute_bulk_instance.spot", 1),
					testAccCheckComputeBulkInstanceFirstInstance(t, "google_compute_bulk_instance.spot", func(instance *compute.Instance) error {
						if instance.Scheduling == nil {
							return fmt.Errorf("expected scheduling on spot instance")
						}
						if instance.Scheduling.ProvisioningModel != "SPOT" {
							return fmt.Errorf("expected ProvisioningModel SPOT, got %q", instance.Scheduling.ProvisioningModel)
						}
						if !instance.Scheduling.Preemptible {
							return fmt.Errorf("expected Preemptible true on spot instance")
						}
						wantMaxRun := compute.Duration{Seconds: 3600, Nanos: 0}
						if err := bulkRunInstanceCheck(instance, testAccCheckComputeInstanceMaxRunDuration(instance, wantMaxRun)); err != nil {
							return err
						}
						return bulkRunInstanceCheck(instance, testAccCheckComputeInstanceTerminationAction(instance, "STOP"))
					}),
				),
			},
		},
	})
}

