func testAccCheckComputeBulkInstanceDestroyProducer(t *testing.T) func(s *terraform.State) error {
	return func(s *terraform.State) error {
		for _, rs := range s.RootModule().Resources {
			if rs.Type != "google_compute_bulk_instance" {
				continue
			}

			instances, err := testAccListComputeBulkInstances(t, rs.Primary.Attributes["project"], rs.Primary.Attributes["zone"], rs.Primary.Attributes["name_pattern"], testAccComputeBulkInstanceStateNames(rs.Primary.Attributes))
			if err != nil {
				return err
			}

			if len(instances) == 0 {
				continue
			}

			names := make([]string, 0, len(instances))
			for _, instance := range instances {
				names = append(names, instance.Name)
			}

			return fmt.Errorf("tracked bulk instances still exist: %s", strings.Join(names, ", "))
		}

		return nil
	}
}

func testAccComputeBulkInstanceStateNames(attrs map[string]string) []string {
	count := 0
	if rawCount, ok := attrs["instance_names.#"]; ok {
		fmt.Sscanf(rawCount, "%d", &count)
	}

	names := make([]string, 0, count)
	for i := 0; i < count; i++ {
		if name, ok := attrs[fmt.Sprintf("instance_names.%d", i)]; ok && name != "" {
			names = append(names, name)
		}
	}
	return names
}

func testAccListComputeBulkInstances(t *testing.T, project, zone, namePattern string, explicitNames []string) ([]*compute.Instance, error) {
	config := acctest.GoogleProviderConfig(t)
	if project == "" {
		project = envvar.GetTestProjectFromEnv()
	}

	var nameRe *regexp.Regexp
	var err error
	if namePattern != "" {
		nameRe, err = testAccComputeBulkInstanceNameRegexp(namePattern)
		if err != nil {
			return nil, err
		}
	}

	explicitNameSet := make(map[string]struct{}, len(explicitNames))
	for _, name := range explicitNames {
		if name != "" {
			explicitNameSet[name] = struct{}{}
		}
	}

	instances := make([]*compute.Instance, 0)
	seen := make(map[string]struct{})
	req := config.NewComputeClient(config.UserAgent).Instances.List(project, zone)
	err = req.Pages(context.Background(), func(page *compute.InstanceList) error {
		for _, instance := range page.Items {
			if instance == nil {
				continue
			}
			if nameRe != nil && nameRe.MatchString(instance.Name) {
				if _, ok := seen[instance.Name]; !ok {
					instances = append(instances, instance)
					seen[instance.Name] = struct{}{}
				}
				continue
			}
			if _, ok := explicitNameSet[instance.Name]; ok {
				if _, ok := seen[instance.Name]; !ok {
					instances = append(instances, instance)
					seen[instance.Name] = struct{}{}
				}
			}
		}
		return nil
	})
	if err != nil {
		return nil, err
	}

	return instances, nil
}

func testAccComputeBulkInstanceNameRegexp(namePattern string) (*regexp.Regexp, error) {
	var builder strings.Builder
	builder.WriteString("^")

	for i := 0; i < len(namePattern); {
		if namePattern[i] == '#' {
			j := i
			for j < len(namePattern) && namePattern[j] == '#' {
				j++
			}
			builder.WriteString(fmt.Sprintf(`[0-9]{%d}`, j-i))
			i = j
			continue
		}

		builder.WriteString(regexp.QuoteMeta(string(namePattern[i])))
		i++
	}

	builder.WriteString("$")
	return regexp.Compile(builder.String())
}

